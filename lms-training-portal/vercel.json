{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/static/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_CLIENT_ID": "@react_app_client_id",
    "REACT_APP_TENANT_ID": "@react_app_tenant_id",
    "REACT_APP_AUTHORITY": "@react_app_authority",
    "REACT_APP_SHAREPOINT_SITE": "@react_app_sharepoint_site"
  }
}
