{
  "buildCommand": "npm --prefix lms-training-portal install && npm --prefix lms-training-portal run build",
  "outputDirectory": "lms-training-portal/build",
  "functions": {
    "api/proxy.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
